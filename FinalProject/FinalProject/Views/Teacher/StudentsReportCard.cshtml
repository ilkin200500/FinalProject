@model IEnumerable<FinalProject.Models.Grade>

@{
    ViewData["Title"] = "Tələbələrin Qiymət Cədvəli";
}

<div class="container-fluid pt-4 px-4">
    <div class="mb-4">
        <a asp-controller="Teacher" asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3" style="border-radius: 6px;">
            <i class="fa-solid fa-arrow-left me-1"></i> Fənlərə Geri Dön
        </a>
        <h2 class="text-dark font-weight-bold mb-1" style="font-size: 26px;">
            @(ViewBag.CourseName ?? "Fənnin Qiymət Cədvəli")
        </h2>
        <p class="text-muted small mb-0">Bu fənni götürən tələbələrin akademik göstəriciləri</p>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="card-body p-3 bg-white">
            <div class="table-responsive">
                <table class="table align-middle mb-0" style="font-size: 14px; table-layout: fixed; width: 100%;">
                    <thead class="table-light text-secondary" style="font-weight: 600; font-size: 13px; background-color: #f8f9fc; border-bottom: 2px solid #eaecf4;">
                        <tr>
                            <th class="ps-4 py-3" style="width: 35%; text-align: left;">TƏLƏBƏNİN TAM ADI</th>
                            <th class="text-center py-3" style="width: 15%;">GİRİŞ BALI (MİDS)</th>
                            <th class="text-center py-3" style="width: 15%;">FİNAL BALI</th>
                            <th class="text-center py-3" style="width: 12%;">YEKUN BAL</th>
                            <th class="text-center py-3" style="width: 11%;">HƏRF</th>
                            <th class="text-center pe-4 py-3" style="width: 12%;">ƏMƏLİYYAT</th>
                        </tr>
                    </thead>
                    <tbody style="font-size: 15px; color: #4e5d78;">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var student in Model)
                            {
                                <tr style="transition: background-color 0.2s;">
                                    <td class="ps-4 py-3 text-dark font-weight-bold" style="text-align: left; vertical-align: middle;">
                                        @* Grade modelində Student və ya User əlaqəsi necədirsə bura yazılır (Məs: student.Student?.FullName) *@
                                        @(student.Student?.FullName ?? "Məlumat yoxdur")
                                    </td>

                                    <td class="text-center py-3" style="vertical-align: middle;">
                                        <input type="number" name="midtermScore" value="@student.Mids"
                                               class="form-control form-control-sm text-center mx-auto"
                                               style="max-width: 75px; border-radius: 6px; font-weight: 600; border: 1px solid #ced4da;" min="0" max="50" />
                                    </td>

                                    <td class="text-center py-3" style="vertical-align: middle;">
                                        <input type="number" name="finalScore" value="@student.Final"
                                               class="form-control form-control-sm text-center mx-auto"
                                               style="max-width: 75px; border-radius: 6px; font-weight: 600; border: 1px solid #ced4da;" min="0" max="50" />
                                    </td>

                                    <td class="text-center py-3 font-weight-bold text-success" style="font-size: 16px; vertical-align: middle;">
                                        @(student.Mids+student.Final)
                                    </td>

                                    <td class="text-center py-3" style="vertical-align: middle;">
                                        @if (!string.IsNullOrEmpty(student.LetterGrade) && student.LetterGrade.Trim() != "-")
                                        {
                                            <span class="d-inline-flex align-items-center justify-content-center text-white font-weight-bold"
                                                  style="background-color: #198754; border-radius: 6px; font-size: 13px; width: 36px; height: 26px; box-shadow: 0 2px 4px rgba(25, 135, 84, 0.15);">
                                                @student.LetterGrade
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="d-inline-flex align-items-center justify-content-center text-secondary border font-weight-bold"
                                                  style="background-color: #f8f9fc; border-radius: 6px; font-size: 13px; width: 36px; height: 26px; border-color: #dee2e6 !important;">
                                                -
                                            </span>
                                        }
                                    </td>

                                    <td class="text-center pe-4 py-3" style="vertical-align: middle;">
                                        <form asp-action="SaveGrade" asp-controller="Teacher" method="post" class="m-0">
                                            <input type="hidden" name="id" value="@student.Id" />
                                            <button type="submit" class="btn btn-sm btn-success text-white font-weight-bold shadow-sm d-flex align-items-center justify-content-center mx-auto"
                                                    style="border-radius: 6px; padding: 6px 14px; font-size: 13px; white-space: nowrap;">
                                                <i class="fa-solid fa-floppy-disk me-1"></i> Yadda Saxla
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    Bu fənn üzrə qeydiyyatdan keçmiş tələbə tapılmadı.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>