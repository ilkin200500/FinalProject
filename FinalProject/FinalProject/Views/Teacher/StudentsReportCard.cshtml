@model IEnumerable<FinalProject.Models.Grade>

@{
    ViewData["Title"] = ViewBag.CourseName + " - Qiymətləndirmə";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Fənn: <span class="text-primary">@ViewBag.CourseName</span></h2>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left"></i> Fənlərə Qayıt</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Tələbə ID / Məlumat</th>
                        <th style="width: 15%;">Giriş Balı (Mids)</th>
                        <th style="width: 15%;">Final Balı</th>
                        <th>Yekun (Total)</th>
                        <th>Hərf Qiyməti</th>
                        <th>Semestr</th>
                        <th>Əməliyyat</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">Bu fənn üzrə qiymət qeydi tapılmadı.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var grade in Model)
                        {
                            <tr>
                                <td>Tələbə #@grade.StudentId</td>
                                <form asp-action="AssignGrade" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="studentId" value="@grade.StudentId" />
                                    <input type="hidden" name="courseId" value="@ViewBag.CourseId" />

                                <td>
                                    <input type="number" name="mids" value="@grade.Mids" class="form-control form-control-sm" min="0" max="100" required />
                                </td>
                                <td>
                                    <input type="number" name="final" value="@grade.Final" class="form-control form-control-sm" min="0" max="100" required />
                                </td>
                                <td>
                                    <span class="badge @(grade.Total >= 51 ? "bg-success" : "bg-danger")">@grade.Total</span>
                                </td>
                                <td>
                                    <strong>@grade.LetterGrade</strong>
                                </td>
                                <td>
                                    <input type="text" name="semester" value="@grade.Semester" class="form-control form-control-sm" style="max-width: 110px;" />
                                </td>
                                <td>
                                    <button type="submit" class="btn btn-sm btn-success w-100">
                                        <i class="fas fa-save"></i> Yadda saxla
                                    </button>
                                </td>
                                </form>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>