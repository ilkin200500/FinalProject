@model IEnumerable<FinalProject.Models.Course>

@{
    ViewData["Title"] = "Tədris Olunan Fənlər";
}

<div class="container mt-4">
    <h2 class="mb-4 text-primary"><i class="fas fa-book"></i> Mənim Fənlərim</h2>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="alert alert-info">Sizə təhkim olunmuş fənn tapılmadı.</div>
            </div>
        }
        else
        {
            @foreach (var course in Model)
            {
                <div class="col-md-4 mb-3">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-dark">@course.CourseName</h5>
                            <h6 class="card-subtitle mb-2 text-muted">Kod: @course.CourseCode</h6>
                            <p class="card-text">Kredit: <span class="badge bg-secondary">@course.Credits</span></p>

                            <div class="mt-auto">
                                <a asp-action="StudentsReportCard" asp-route-courseId="@course.Id" class="btn btn-primary w-100">
                                    <i class="fas fa-users-cog"></i> Tələbələr və Qiymətlər
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>