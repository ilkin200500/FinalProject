@model IEnumerable<FinalProject.Models.Schedule>

@{
    ViewData["Title"] = "Mənim Dərslərim";
}

<div class="container-fluid pt-4">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded text-center mb-4" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded text-center mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark font-weight-bold" style="font-size: 26px; margin: 0;">Tədris Etdiyim Fənlər</h2>
            <p class="text-muted small mb-0">Cari semestrdə sizə təyin olunmuş dərslərin siyahısı</p>
        </div>
        <span class="d-inline-block text-white px-3 py-2 font-weight-semibold"
              style="background-color: #4e73df; border-radius: 50px; font-size: 13px;">
            Cari Semestr: 2026 Payız
        </span>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0" style="border-radius: 12px; transition: transform 0.2s; border-top: 4px solid #4e73df !important;">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <span class="d-inline-block text-primary border px-2 py-1 font-weight-bold"
                                          style="font-size: 11px; border-color: #4e73df !important; background-color: #f8f9fc; border-radius: 6px;">
                                        @item.Course.CourseCode
                                    </span>
                                    <span class="badge bg-secondary text-white font-weight-bold" style="font-size: 11px; border-radius: 6px; padding: 5px 8px;">
                                        <i class="fa-solid fa-users me-1"></i> @item.Group.GroupName
                                    </span>
                                </div>
                                <h4 class="card-title text-dark font-weight-bold mb-1" style="font-size: 18px; line-height: 1.4;">
                                    @item.Course.CourseName
                                </h4>
                                <small class="text-muted d-block mb-3"><i class="fa-solid fa-star text-warning"></i> @item.Course.Credits Kredit</small>
                            </div>

                            <div class="mt-4 border-top pt-3">
                                <div class="d-flex gap-2">
                                    <a asp-controller="Teacher"
                                       asp-action="StudentsReportCard"
                                       asp-route-courseId="@item.CourseId"
                                       asp-route-groupId="@item.GroupId"
                                       class="btn btn-primary flex-fill font-weight-bold text-white d-flex align-items-center justify-content-center"
                                       style="border-radius: 8px; padding: 10px; font-size: 14px;">
                                        <i class="fa-solid fa-star me-2"></i> Qiymət
                                    </a>

                                    <a asp-controller="Attendance"
                                       asp-action="MarkAttendance"
                                       asp-route-courseId="@item.CourseId"
                                       asp-route-groupId="@item.GroupId"
                                       class="btn btn-success flex-fill font-weight-bold text-white d-flex align-items-center justify-content-center"
                                       style="border-radius: 8px; padding: 10px; font-size: 14px;">
                                        <i class="fa-solid fa-calendar-check me-2"></i> Davamiyyət
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="p-4 bg-white shadow-sm rounded" style="max-width: 500px; margin: 0 auto; border-radius: 12px;">
                    <i class="fa-solid fa-book-open text-muted" style="font-size: 48px;"></i>
                    <h5 class="mt-3 font-weight-bold text-dark">Sizə təyin olunmuş fənn tapılmadı</h5>
                    <p class="text-muted small">Əgər bir xəta olduğunu düşünürsünüzsə, lütfən Administrasiya ilə əlaqə saxlayın.</p>
                </div>
            </div>
        }
    </div>
</div>