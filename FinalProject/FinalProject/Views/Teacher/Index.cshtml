@model IEnumerable<FinalProject.Models.Course>

@{
    ViewData["Title"] = "Mənim Dərslərim";
}

<div class="container-fluid pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark font-weight-bold" style="font-size: 26px; margin: 0;">Tədris Etdiyim Fənlər</h2>
            <p class="text-muted small mb-0">Cari semestrdə sizə təyin olunmuş dərslərin siyahısı</p>
        </div>
        <span class="badge bg-primary text-white px-3 py-2 rounded-pill font-weight-semibold" style="font-size: 13px;">
            Cari Semestr: 2026 Payız
        </span>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var course in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0" style="border-radius: 12px; transition: transform 0.2s; border-top: 4px solid #4e73df !important;">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <span class="badge bg-light text-primary font-weight-bold px-2 py-1" style="font-size: 11px; border: 1px solid #4e73df;">
                                        @course.CourseCode
                                    </span>
                                    <small class="text-muted"><i class="mdi mdi-star text-warning"></i> @course.Credits Kredit</small>
                                </div>
                                <h4 class="card-title text-dark font-weight-bold mb-3" style="font-size: 18px; line-height: 1.4;">
                                    @course.CourseName
                                </h4>
                            </div>

                            <div class="mt-4 border-top pt-3">
                                <a asp-controller="Teacher" asp-action="StudentsReportCard" asp-route-courseId="@course.Id" class="btn btn-primary w-100 font-weight-bold text-white d-flex align-items-center justify-content-center" style="border-radius: 8px; padding: 10px;">
                                    <i class="mdi mdi-notebook-edit-outline me-2" style="font-size: 16px;"></i> Qiymət Jurnalı
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="p-4 bg-white shadow-sm rounded" style="max-width: 500px; margin: 0 auto; border-radius: 12px;">
                    <i class="mdi mdi-book-open-blank-variant text-muted" style="font-size: 48px;"></i>
                    <h5 class="mt-3 font-weight-bold text-dark">Sizə təyin olunmuş fənn tapılmadı</h5>
                    <p class="text-muted small">Əgər bir xəta olduğunu düşünürsünüzsə, lütfən Adminstrasiya ilə əlaqə saxlayın.</p>
                </div>
            </div>
        }
    </div>
</div>