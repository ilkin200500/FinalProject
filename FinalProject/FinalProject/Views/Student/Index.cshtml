@model IEnumerable<FinalProject.Models.Grade>

@{
    ViewData["Title"] = "Semestr Qiymətlərim";
}

<div class="dashboard-wrapper" style="padding: 10px;">

    <div class="welcome-banner" style="background: linear-gradient(135deg, #4e73df 0%, #224abe 100%); color: white; padding: 30px; border-radius: 15px; margin-bottom: 25px; box-shadow: 0 4px 15px rgba(78, 115, 223, 0.25);">
        <h2 style="margin: 0 0 10px 0; font-weight: 600; font-size: 28px;">Xoş gəldiniz, @ViewBag.StudentName! 👋</h2>
        <p style="margin: 0; opacity: 0.9; font-size: 15px;">Cari semestr üzrə akademik göstəriciləriniz və imtahan nəticələriniz aşağıda qeyd olunmuşdur.</p>
    </div>

    <div class="stats-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 30px;">

        <div class="stat-card" style="background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.03); border-left: 5px solid #4e73df; display: flex; justify-content: space-between; align-items: center;">
            <div>
                <span style="color: #858796; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Götürülən Fənlər</span>
                <h3 style="font-size: 26px; margin: 5px 0 0 0; color: #5a5c69; font-weight: 600;">@Model.Count()</h3>
            </div>
            <i class="fa-solid fa-book-bookmark" style="font-size: 28px; color: #dddfeb;"></i>
        </div>

        <div class="stat-card" style="background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.03); border-left: 5px solid #1cc88a; display: flex; justify-content: space-between; align-items: center;">
            <div>
                <span style="color: #858796; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Semestr Orta Balı</span>
                <h3 style="font-size: 26px; margin: 5px 0 0 0; color: #1cc88a; font-weight: 600;">
                    @(Model.Any() ? string.Format("{0:0.00}", Model.Average(g => g.Total)) : "0.00")
                </h3>
            </div>
            <i class="fa-solid fa-chart-line" style="font-size: 28px; color: #dddfeb;"></i>
        </div>

        <div class="stat-card" style="background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.03); border-left: 5px solid #e74a3b; display: flex; justify-content: space-between; align-items: center;">
            <div>
                <span style="color: #858796; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Kəsir Sayı</span>
                <h3 style="font-size: 26px; margin: 5px 0 0 0; color: #e74a3b; font-weight: 600;">@Model.Count(g => g.Total < 51)</h3>
            </div>
            <i class="fa-solid fa-triangle-exclamation" style="font-size: 28px; color: #dddfeb;"></i>
        </div>
    </div>

    <div class="card-table-container" style="background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.02);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid #f0f0f0; padding-bottom: 15px;">
            <h3 style="margin: 0; color: #3a3b45; font-weight: 600; font-size: 18px;">
                <i class="fa-solid fa-graduation-cap" style="color: #4e73df; margin-right: 8px;"></i> Akademik Qiymət Jurnalı
            </h3>
            <span style="background: #eaecf4; color: #4e73df; padding: 5px 12px; border-radius: 20px; font-size: 12px; font-weight: 600;">
                @(Model.FirstOrDefault()?.Semester ?? "Cari Semestr")
            </span>
        </div>

        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 14px;">
                <thead>
                    <tr style="background-color: #f8f9fc; border-bottom: 2px solid #e3e6f0; color: #4e73df; font-weight: 600;">
                        <th style="padding: 15px;">Fənn Kodu</th>
                        <th style="padding: 15px;">Fənnin Adı</th>
                        <th style="padding: 15px; text-align: center;">Kredit</th>
                        <th style="padding: 15px; text-align: center;">Giriş Balı (Mids)</th>
                        <th style="padding: 15px; text-align: center;">Final Balı</th>
                        <th style="padding: 15px; text-align: center;">Yekun Bal</th>
                        <th style="padding: 15px; text-align: center;">Hərf Qiyməti</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var grade in Model)
                        {
                            <tr style="border-bottom: 1px solid #e3e6f0; transition: background 0.2s;" onmouseover="this.style.backgroundColor='#f8f9fc'" onmouseout="this.style.backgroundColor='transparent'">
                                <td style="padding: 15px; font-weight: 600; color: #4e73df;">@grade.Course?.CourseCode</td>
                                <td style="padding: 15px; color: #5a5c69; font-weight: 500;">@grade.Course?.CourseName</td>
                                <td style="padding: 15px; text-align: center; color: #858796;">@grade.Course?.Credits</td>
                                <td style="padding: 15px; text-align: center; font-weight: 600; color: #5a5c69;">@grade.Mids / 50</td>
                                <td style="padding: 15px; text-align: center; font-weight: 600; color: #5a5c69;">@grade.Final / 50</td>
                                <td style="padding: 15px; text-align: center; font-weight: 700; font-size: 15px; color: @(grade.Total >= 51 ? "#1cc88a" : "#e74a3b")">
                                    @grade.Total
                                </td>
                                <td style="padding: 15px; text-align: center;">
                                    <span style="padding: 6px 14px; border-radius: 30px; font-weight: 700; font-size: 12px; display: inline-block; min-width: 35px; text-align: center;
                                                          background-color: @(grade.Total >= 51 ? "rgba(28, 200, 138, 0.15)" : "rgba(231, 74, 59, 0.15)");
                                                          color: @(grade.Total >= 51 ? "#1cc88a" : "#e74a3b");">
                                        @grade.LetterGrade
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" style="padding: 30px; text-align: center; color: #858796; font-size: 15px;">
                                <i class="fa-regular fa-folder-open" style="display: block; font-size: 30px; margin-bottom: 10px; color: #dddfeb;"></i>
                                Hələ ki, cari semestr üzrə heç bir qiymət daxil edilməyib.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>