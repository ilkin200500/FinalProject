@model IEnumerable<FinalProject.Models.Course>

@{
    ViewData["Title"] = "Fənn Seçimi";
}

<div class="container-fluid pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark font-weight-bold" style="font-size: 26px; margin: 0;">
                <i class="mdi mdi-book-open-page-variant text-success mr-2"></i> Yeni Semestr Fənn Seçimi
            </h2>
            <p class="text-muted small mb-0">Cari semestr üzrə qeydiyyatdan keçə biləcəyiniz aktiv dərslər</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm font-weight-bold d-flex justify-content-between align-items-center" role="alert" style="border-radius: 8px;">
            <div>
                <i class="mdi mdi-check-circle mr-2"></i> @TempData["Success"]
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm font-weight-bold d-flex justify-content-between align-items-center" role="alert" style="border-radius: 8px;">
            <div>
                <i class="mdi mdi-alert-circle mr-2"></i> @TempData["Error"]
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="card-body p-0 bg-white">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle" style="font-size: 14px;">
                    <thead class="bg-light" style="border-bottom: 2px solid #e3e6f0;">
                        <tr class="text-success font-weight-bold">
                            <th style="padding: 15px;">Fənn Kodu</th>
                            <th style="padding: 15px;">Fənnin Adı</th>
                            <th style="padding: 15px; text-align: center;">Müəllim</th>
                            <th style="padding: 15px; text-align: center;">Kredit</th>
                            <th style="padding: 15px; text-align: center;">Əməliyyat</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    <i class="mdi mdi-checkbox-marked-circle-outline d-block mb-2" style="font-size: 32px; color: #28a745;"></i>
                                    Seçilə biləcək yeni fənn yoxdur. Bütün fənləri uğurla seçmisiniz!
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var course in Model)
                            {
                                <tr style="border-bottom: 1px solid #e3e6f0;">
                                    <td style="padding: 15px;">
                                        <span class="badge bg-light text-success font-weight-bold px-2 py-1" style="border: 1px solid #28a745; font-size: 12px;">
                                            #@course.Id.ToString("D4")
                                        </span>
                                    </td>
                                    <td style="padding: 15px;" class="font-weight-bold text-dark">
                                        @course.CourseName
                                    </td>
                                    <td style="padding: 15px; text-align: center;">
                                        @{
                                            var teacherName = "Təyin edilməyib";
                                            if (course.Schedules != null && course.Schedules.Any())
                                            {
                                                var firstSchedule = course.Schedules.FirstOrDefault();
                                                if (firstSchedule?.Teacher != null)
                                                {
                                                    teacherName = firstSchedule.Teacher.FullName;
                                                }
                                            }
                                        }
                                        <span class="badge bg-light text-secondary border px-2 py-1">
                                            <i class="mdi mdi-account-tie mr-1"></i> @teacherName
                                        </span>
                                    </td>
                                    <td style="padding: 15px; text-align: center;" class="text-muted font-weight-medium">
                                        3 Kredit
                                    </td>
                                    <td style="padding: 15px; text-align: center;">
                                        <form asp-action="EnrollCourse" asp-controller="Student" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="courseId" value="@course.Id" />
                                            <button type="submit" class="btn btn-sm btn-success text-white font-weight-bold shadow-sm" style="border-radius: 6px;">
                                                <i class="mdi mdi-plus mr-1"></i> Fənni Götür
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>