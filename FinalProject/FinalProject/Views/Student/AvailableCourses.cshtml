@model IEnumerable<FinalProject.Models.Course>

@{
    ViewData["Title"] = "Fənn Seçimi";
}

<div class="container-fluid pt-4 px-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="text-dark font-weight-bold" style="font-size: 26px; margin: 0;">
                <i class="mdi mdi-book-open-page-variant text-success me-2"></i> Yeni Semestr Fənn Seçimi
            </h2>
            <p class="text-muted small mb-0">Cari semestr üzrə qeydiyyatdan keçə biləcəyiniz aktiv dərslər</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert" style="border-radius: 8px;">
            <i class="mdi mdi-check-circle me-2"></i> <strong>@TempData["Success"]</strong>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert" style="border-radius: 8px;">
            <i class="mdi mdi-alert-circle me-2"></i> <strong>@TempData["Error"]</strong>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="card-body p-3 bg-white">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0" style="font-size: 14px; table-layout: fixed; width: 100%;">
                    <thead class="table-light">
                        <tr class="text-success font-weight-bold">
                            <th style="width: 20%; padding: 15px;">Fənn Kodu</th>
                            <th style="width: 50%; padding: 15px;">Fənnin Adı</th>
                            <th style="width: 15%; padding: 15px; text-align: center;">Kredit</th>
                            <th style="width: 15%; padding: 15px; text-align: center;">Əməliyyat</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-5">
                                    <i class="mdi mdi-checkbox-marked-circle-outline d-block mb-2" style="font-size: 32px; color: #28a745;"></i>
                                    Seçilə biləcək yeni fənn yoxdur. Bütün fənləri uğurla seçmisiniz!
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var course in Model)
                            {
                                <tr>
                                    <!-- Fənn Kodu -->
                                    <td style="padding: 15px; vertical-align: middle;">
                                        <span class="d-inline-block text-success border px-2 py-1 font-weight-bold"
                                              style="background-color: #f8f9fc; border-radius: 6px; font-size: 12px; border-color: #28a745 !important; min-width: 80px; text-align: center;">
                                            @(string.IsNullOrEmpty(course.CourseCode) ? $"#{course.Id.ToString("D4")}" : course.CourseCode)
                                        </span>
                                    </td>

                                    <!-- Fənnin Adı -->
                                    <td style="padding: 15px; vertical-align: middle;" class="font-weight-bold text-dark">
                                        @course.CourseName
                                    </td>

                                    <!-- Kredit -->
                                    <td style="padding: 15px; text-align: center; vertical-align: middle;" class="text-muted font-weight-medium">
                                        @course.Credits Kredit
                                    </td>

                                    <!-- Fənni Götür Düyməsi -->
                                    <td style="padding: 15px; text-align: center; vertical-align: middle;">
                                        <form asp-action="EnrollCourse" asp-controller="Student" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="courseId" value="@course.Id" />
                                            <button type="submit" class="btn btn-sm btn-success text-white font-weight-bold shadow-sm" style="border-radius: 6px; white-space: nowrap;">
                                                <i class="mdi mdi-plus me-1"></i> Fənni Götür
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>