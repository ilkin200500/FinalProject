@model IEnumerable<FinalProject.Models.Assignment>

@{
    ViewData["Title"] = "Ev Tapşırıqlarım";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fas fa-book-reader text-primary me-2"></i>Ev Tapşırıqlarım
            <small class="text-muted fs-6">(@ViewBag.GroupName)</small>
        </h2>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="card shadow-sm text-center py-5">
                    <div class="card-body">
                        <i class="fas fa-check-circle fa-4x text-success mb-3"></i>
                        <h4>Təbriklər!</h4>
                        <p class="text-muted">Qrupunuz üçün hələ ki heç bir ev tapşırığı təyin edilməyib.</p>
                    </div>
                </div>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                bool isExpired = item.DueDate < DateTime.Now;
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 @(isExpired ? "border-top-danger" : "border-top-primary")" style="border-top: 4px solid;">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge bg-primary">@(item.Course?.CourseName ?? "Fənn")</span>
                                @if (isExpired)
                                {
                                    <span class="badge bg-danger">Müddət bitib</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Aktiv</span>
                                }
                            </div>

                            <h5 class="card-title mt-2">@item.Title</h5>
                            <p class="card-text text-muted flex-grow-1">
                                @(string.IsNullOrEmpty(item.Description) ? "Təsvir qeyd edilməyib." : item.Description)
                            </p>

                            <hr />

                            <div class="small text-muted mb-1">
                                <i class="fas fa-user-tie me-1"></i> Müəllim: <strong>@(item.Teacher?.FullName ?? "Qeyd edilməyib")</strong>
                            </div>
                            <div class="small text-muted mb-1">
                                <i class="fas fa-calendar-alt me-1"></i> Verildi: @item.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                            </div>
                            <div class="small text-muted">
                                <i class="fas fa-clock me-1"></i> Son tarix: <strong class="@(isExpired ? "text-danger" : "text-dark")">@item.DueDate.ToString("dd.MM.yyyy HH:mm")</strong>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>