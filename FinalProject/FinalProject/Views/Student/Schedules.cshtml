@model IEnumerable<FinalProject.Models.Schedule>

@{
    ViewData["Title"] = "Dərs Cədvəlim";

    // C#-ın daxili DayOfWeek enum sırasına uyğun sistem qururuq (Bazar ertəsindən Şənbəyə qədər)
    var daysOrder = new List<(System.DayOfWeek DayEnum, string DayName)>
    {
        (System.DayOfWeek.Monday, "Bazar ertəsi"),
        (System.DayOfWeek.Tuesday, "Çərşənbə axşamı"),
        (System.DayOfWeek.Wednesday, "Çərşənbə"),
        (System.DayOfWeek.Thursday, "Cümə axşamı"),
        (System.DayOfWeek.Friday, "Cümə"),
        (System.DayOfWeek.Saturday, "Şənbə")
    };
}

<div class="container-fluid pt-4 px-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4 pb-3 border-bottom">
        <div>
            <div class="d-flex align-items-center gap-2 mb-1">
                <i class="fa-solid fa-calendar-days text-primary" style="font-size: 28px;"></i>
                <h2 class="text-dark font-weight-bold m-0" style="font-size: 28px; letter-spacing: -0.5px;">Həftəlik Dərs Cədvəlim</h2>
            </div>
            <p class="text-muted small mb-0">Hörmətli <strong>@ViewBag.StudentName</strong>, aid olduğunuz <strong><span class="text-primary">@ViewBag.GroupName</span></strong> qrupunun dərs cədvəli.</p>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="col-12 text-center py-5">
            <div class="p-5 bg-white shadow-sm rounded-4 border-0" style="max-width: 550px; margin: 0 auto; border-radius: 16px;">
                <div class="mb-4 bg-light d-inline-flex align-items-center justify-content-center rounded-circle" style="width: 90px; height: 90px;">
                    <i class="fa-solid fa-calendar-xmark text-muted" style="font-size: 40px;"></i>
                </div>
                <h5 class="font-weight-bold text-dark mb-2" style="font-size: 20px;">Cədvəl tapılmadı</h5>
                <p class="text-muted small mb-0 px-3">Bu qrup üçün admin tərəfindən hələ heç bir dərs cədvəli daxil edilməyib.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0" style="border-radius: 16px; overflow: hidden; background: #ffffff;">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="table-layout: fixed; width: 100%;">
                    <thead class="table-light text-secondary" style="font-weight: 600; font-size: 14px; background-color: #f8f9fc; border-bottom: 2px solid #eaecf4;">
                        <tr>
                            <th class="ps-4 py-3" style="width: 180px;">Həftənin Günü</th>
                            <th class="py-3" style="width: 25%;">Fənnin Adı</th>
                            <th class="py-3" style="width: 20%;">Müəllim</th>
                            <th class="text-center py-3" style="width: 130px;">Otaq / Sinif</th>
                            <th class="text-center pe-4 py-3" style="width: 180px;">Dərs Saatı</th>
                        </tr>
                    </thead>
                    <tbody style="font-size: 15px; color: #4e5d78;">
                        @foreach (var dayItem in daysOrder)
                        {
                            // Süzgəcləməni Enum tipinə görə edirik
                            var dayLessons = Model.Where(s => s.DayOfWeek == dayItem.DayEnum).ToList();

                            if (dayLessons.Any())
                            {
                                foreach (var lesson in dayLessons)
                                {
                                    <tr style="transition: background-color 0.2s;">
                                        @if (lesson == dayLessons.First())
                                        {
                                            // Rowspan ilə gün adının təkrarlanmasının qarşısını alırıq
                                            <td class="ps-4 py-3 font-weight-bold text-primary bg-light-subtle align-middle" rowspan="@dayLessons.Count" style="font-size: 16px; border-right: 1px solid #eaecf4;">
                                                <i class="fa-regular fa-clock me-1 text-secondary"></i> @dayItem.DayName
                                            </td>
                                        }

                                        <td class="py-3 text-dark font-weight-bold" style="font-size: 15px;">
                                            @(lesson.Course?.CourseName ?? "Bilinməyən Fənn")
                                            <span class="d-inline-block text-secondary border ms-2 px-2 py-0.5 small"
                                                  style="font-size: 11px; background-color: #f8f9fc; border-radius: 4px; border-color: #dee2e6 !important;">
                                                @(lesson.Course?.CourseCode)
                                            </span>
                                        </td>

                                        <td class="py-3 text-secondary">
                                            <i class="fa-solid fa-chalkboard-user me-1 text-muted"></i>
                                            @(lesson.Teacher != null ? lesson.Teacher.FullName : "Təyin olunmayıb")
                                        </td>

                                        <td class="text-center py-3">
                                            <span class="d-inline-block text-secondary border px-3 py-1 font-weight-bold"
                                                  style="background-color: #f8f9fc; border-radius: 8px; font-size: 13px; min-width: 80px; text-align: center; border-color: #dee2e6 !important;">
                                                @(string.IsNullOrEmpty(lesson.Classroom) ? "Onlayn" : lesson.Classroom)
                                            </span>
                                        </td>

                                        <td class="text-center pe-4 py-3">
                                            <span class="d-inline-block text-white px-3 py-1.5 font-weight-bold"
                                                  style="background-color: #0d6efd; border-radius: 8px; font-size: 13px; min-width: 110px; text-align: center; box-shadow: 0 2px 4px rgba(13, 110, 253, 0.15);">
                                                @lesson.StartTime.ToString(@"hh\:mm") - @lesson.EndTime.ToString(@"hh\:mm")
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>