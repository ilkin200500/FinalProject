@{
    // 🎯 Cari Controller, Action və Area adlarını avtomatik tuturuq
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
}

<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Information System</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/style.css">

    <style>
        /* 🎨 Əgər CSS-də yoxdursa, aktiv keçidin soluna kiçik xətt effekti və rəng qatırıq */
        .nav-menu .nav-item.active {
            background-color: rgba(78, 115, 223, 0.1);
            color: #4e73df;
            font-weight: 600;
            border-left: 4px solid #4e73df;
            padding-left: 16px; /* xətt gəldiyi üçün dizayn sürüşməsin deyə */
        }
    </style>
</head>
<body>

    <div class="app-container">

        <aside class="sidebar">
            <div class="sidebar-top">
                <div class="logo-area">
                    <i class="fa-solid fa-graduation-cap logo-icon"></i>
                    <span class="logo-text">UniVerse SIS</span>
                </div>

                <nav class="nav-menu">
                    <a asp-controller="Home" asp-action="Index" class="nav-item @(currentController == "Home" && currentAction == "Index" ? "active" : "")">
                        <i class="fa-solid fa-chart-pie"></i>
                        <span>Ana Səhifə</span>
                    </a>

                    @if (User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-area="AdminPanel" asp-controller="Dashboard" asp-action="Index" class="nav-item @(currentArea == "AdminPanel" && currentController == "Dashboard" ? "active" : "")">
                                <i class="fa-solid fa-gauge"></i>
                                <span>Admin Panel</span>
                            </a>

                            <a asp-area="AdminPanel" asp-controller="Teacher" asp-action="ShowTeachersTable" class="nav-item @(currentArea == "AdminPanel" && currentController == "Teacher" ? "active" : "")">
                                <i class="fa-solid fa-chalkboard-user"></i>
                                <span>Müəllim İdarəsi</span>
                            </a>

                            <a asp-controller="Home" asp-action="StudentsPage" class="nav-item @(currentController == "Home" && currentAction == "StudentsPage" ? "active" : "")">
                                <i class="fa-solid fa-user-graduate"></i>
                                <span>Tələbə İdarəsi</span>
                            </a>
                        }

                        @if (User.IsInRole("Teacher"))
                        {
                            <a asp-controller="Teacher" asp-action="Index" class="nav-item @(currentController == "Teacher" && currentAction == "Index" && currentArea != "AdminPanel" ? "active" : "")">
                                <i class="fa-solid fa-chalkboard-user"></i>
                                <span>Dərslərim</span>
                            </a>
                            <a href="#" class="nav-item">
                                <i class="fa-solid fa-star"></i>
                                <span>Qiymətləndirmə</span>
                            </a>
                        }

                        @if (User.IsInRole("Student"))
                        {
                            <a asp-controller="Student" asp-action="Index" class="nav-item @(currentController == "Student" && currentAction == "Index" ? "active" : "")">
                                <i class="fa-solid fa-book-reader"></i>
                                <span>Semestr Qiymətlərim</span>
                            </a>
                        }
                    }

                    <a href="#" class="nav-item">
                        <i class="fa-solid fa-book"></i>
                        <span>Fənlər & Dərslər</span>
                    </a>
                </nav>
            </div>

            <div class="sidebar-profile">
                <div class="profile-info">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="profile-avatar">
                            @(User.Identity.Name?.Substring(0, Math.Min(2, User.Identity.Name.Length)).ToUpper() ?? "US")
                        </div>
                        <div>
                            <h4 class="profile-name">@User.Identity.Name</h4>
                            <span class="profile-email">Giriş edilib</span>
                        </div>
                    }
                    else
                    {
                        <div class="profile-avatar">??</div>
                        <div>
                            <h4 class="profile-name">Qonaq</h4>
                            <span class="profile-email">Giriş edilməyib</span>
                        </div>
                    }
                </div>

                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-area="" asp-controller="Account" asp-action="Logout" class="logout-btn" title="Çıxış et">
                        <i class="fa-solid fa-right-from-bracket"></i>
                    </a>
                }
                else
                {
                    <a asp-area="" asp-controller="Account" asp-action="Login" class="logout-btn" title="Giriş et">
                        <i class="fa-solid fa-user"></i>
                    </a>
                }
            </div>
        </aside>

        <main class="main-content">
            <div class="content-body">
                @RenderBody()
            </div>

            <footer class="app-footer">
                <div class="footer-left">
                    <p>&copy; 2026 <strong>UniVerse SIS</strong>. Bütün hüquqlar qorunur.</p>
                </div>
                <div class="footer-right">
                    <a href="#" class="footer-link">Dəstək</a>
                    <span class="footer-divider">|</span>
                    <a href="#" class="footer-link">İstifadəçi Qaydaları</a>
                    <span class="footer-divider">|</span>
                    <span class="version-badge">v1.0.0 (MVC)</span>
                </div>
            </footer>
        </main>

    </div>

</body>
</html>