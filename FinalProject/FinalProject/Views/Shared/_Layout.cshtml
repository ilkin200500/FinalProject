@{
    string currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLower();
    string currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? "").ToLower();
    string currentArea = (ViewContext.RouteData.Values["area"]?.ToString() ?? "").ToLower();
}

<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - UniVerse SIS</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        html, body {
            max-width: 100% !important;
            overflow-x: hidden !important;
            margin: 0;
            padding: 0;
        }

        .app-container {
            max-width: 100% !important;
            overflow-x: hidden !important;
            display: flex;
        }

        .nav-menu .nav-item.active {
            background-color: rgba(78, 115, 223, 0.1);
            color: #4e73df;
            font-weight: 600;
            border-left: 4px solid #4e73df;
            padding-left: 16px;
        }

        .logout-form-container {
            margin: 0;
            padding: 0;
            display: inline;
        }

        .logout-submit-btn {
            background: none;
            border: none;
            color: inherit;
            padding: 0;
            cursor: pointer;
            font: inherit;
        }

        .main-header {
            background-color: #ffffff;
            height: 65px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
            border-bottom: 1px solid #e3e6f0;
            box-shadow: 0 .15rem 1.75rem 0 rgba(58,59,69,.05);
        }

        .header-greeting {
            font-size: 14px;
            color: #5a5c69;
        }

        .notification-bell-btn {
            color: #d1d3e2;
            font-size: 20px;
            position: relative;
            transition: color 0.2s ease-in-out;
            text-decoration: none;
        }

            .notification-bell-btn:hover {
                color: #4e73df;
            }
    </style>
</head>
<body>

    <div class="app-container">

        <aside class="sidebar">
            <div class="sidebar-top">
                <div class="logo-area">
                    <i class="fa-solid fa-graduation-cap logo-icon"></i>
                    <span class="logo-text">UniVerse SIS</span>
                </div>

                <nav class="nav-menu">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-item @(currentArea == "" && currentController == "home" && currentAction == "index" ? "active" : "")">
                        <i class="fa-solid fa-chart-pie"></i>
                        <span>Ana Səhifə</span>
                    </a>

                    @if (User.Identity.IsAuthenticated)
                    {
                        @* ==========================================
                            🛡 ADMIN MENYUSU
                           ========================================== *@
                        if (User.IsInRole("Admin"))
                        {
                            <a asp-area="AdminPanel" asp-controller="Dashboard" asp-action="Index" class="nav-item @(currentArea == "adminpanel" && currentController == "dashboard" ? "active" : "")">
                                <i class="fa-solid fa-gauge"></i>
                                <span>Admin Panel</span>
                            </a>

                            <a asp-area="AdminPanel" asp-controller="Teacher" asp-action="ShowTeachersTable" class="nav-item @(currentArea == "adminpanel" && currentController == "teacher" ? "active" : "")">
                                <i class="fa-solid fa-chalkboard-user"></i>
                                <span>Müəllim İdarəsi</span>
                            </a>

                            <a asp-area="" asp-controller="Home" asp-action="StudentsPage" class="nav-item @(currentController == "home" && currentAction == "studentspage" ? "active" : "")">
                                <i class="fa-solid fa-user-graduate"></i>
                                <span>Tələbə İdarəsi</span>
                            </a>
                        }

                        @* ==========================================
                            👨‍🏫 MÜƏLLİM MENYUSU (Tam Düzgün Keçid və Aktivlik Şərti)
                           ========================================== *@
                        if (User.IsInRole("Teacher"))
                        {
                            <a asp-area=""
                               asp-controller="Teacher"
                               asp-action="Index"
                               class="nav-item @((currentController == "teacher" && (currentAction == "index" || currentAction == "studentsreportcard")) || (currentController == "attendance" && currentAction == "markattendance") ? "active" : "")">
                                <i class="fa-solid fa-chalkboard-user"></i>
                                <span>Tədris Fənlərim</span>
                            </a>
                        }

                        @* ==========================================
                            🎓 TƏLƏBƏ MENYUSU
                           ========================================== *@
                        if (User.IsInRole("Student"))
                        {
                            <a asp-area="" asp-controller="Student" asp-action="Index" class="nav-item @(currentController == "student" && currentAction == "index" ? "active" : "")">
                                <i class="fa-solid fa-book-reader"></i>
                                <span>Semestr Qiymətlərim</span>
                            </a>

                            <a asp-area="" asp-controller="Student" asp-action="AvailableCourses" class="nav-item @(currentController == "student" && currentAction == "availablecourses" ? "active" : "")">
                                <i class="fa-solid fa-book"></i>
                                <span>Fənn Seçimi (Portal)</span>
                            </a>

                            <a asp-area="" asp-controller="Student" asp-action="Schedules" class="nav-item @(currentController == "student" && currentAction == "schedules" ? "active" : "")">
                                <i class="fa-solid fa-calendar-days"></i>
                                <span>Dərs Cədvəlim</span>
                            </a>

                            <a asp-area="" asp-controller="Attendance" asp-action="StudentReport" class="nav-item @(currentController == "attendance" && currentAction == "studentreport" ? "active" : "")">
                                <i class="fa-solid fa-clipboard-user"></i>
                                <span>Davamiyyət Hesabatı</span>
                            </a>
                        }
                    }
                </nav>
            </div>

            <div class="sidebar-profile">
                <div class="profile-info">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="profile-avatar">
                            @(User.Identity.Name?.Substring(0, Math.Min(2, User.Identity.Name.Length)).ToUpper() ?? "US")
                        </div>
                        <div>
                            <h4 class="profile-name">@User.Identity.Name</h4>
                            <span class="profile-email">Giriş edilib</span>
                        </div>
                    }
                    else
                    {
                        <div class="profile-avatar">??</div>
                        <div>
                            <h4 class="profile-name">Qonaq</h4>
                            <span class="profile-email">Giriş edilməyib</span>
                        </div>
                    }
                </div>

                @if (User.Identity.IsAuthenticated)
                {
                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="logout-form-container">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="logout-btn logout-submit-btn" title="Çıxış et">
                            <i class="fa-solid fa-right-from-bracket"></i>
                        </button>
                    </form>
                }
                else
                {
                    <a asp-area="" asp-controller="Account" asp-action="Login" class="logout-btn" title="Giriş et">
                        <i class="fa-solid fa-user"></i>
                    </a>
                }
            </div>
        </aside>

        <main class="main-content" style="overflow-x: hidden; flex: 1; display: flex; flex-direction: column; min-height: 100vh;">

            @if (User.Identity.IsAuthenticated)
            {
                <header class="main-header">
                    <div class="header-left">
                        <span class="header-greeting">
                            <i class="fa-regular fa-hand mr-2 text-primary"></i>
                            Xoş gəldiniz, <strong>@User.Identity.Name</strong>!
                        </span>
                    </div>

                    <div class="header-right d-flex align-items-center">
                        @if (User.IsInRole("Student"))
                        {
                            <ul class="navbar-nav mr-auto">
                                @await Component.InvokeAsync("NotificationHeader")
                            </ul>
                        }
                    </div>
                </header>
            }

            <div class="content-body" style="flex: 1; padding: 25px;">
                @RenderBody()
            </div>

            <footer class="app-footer">
                <div class="footer-left">
                    <p>&copy; 2026 <strong>UniVerse SIS</strong>. Bütün hüquqlar qorunur.</p>
                </div>
                <div class="footer-right">
                    <a href="#" class="footer-link">Dəstək</a>
                    <span class="footer-divider">|</span>
                    <a href="#" class="footer-link">İstifadəçi Qaydaları</a>
                    <span class="footer-divider">|</span>
                    <span class="version-badge">v1.0.0 (MVC)</span>
                </div>
            </footer>
        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>