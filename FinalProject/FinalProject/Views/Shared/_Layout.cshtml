锘緻{
    // 馃幆 D蓹yi艧蓹n adlar谋n谋 tam sinxron formaya sal谋r谋q
    string currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLower();
    string currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? "").ToLower();
    string currentArea = (ViewContext.RouteData.Values["area"]?.ToString() ?? "").ToLower();
}

<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Information System</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/style.css">

    <style>
        .nav-menu .nav-item.active {
            background-color: rgba(78, 115, 223, 0.1);
            color: #4e73df;
            font-weight: 600;
            border-left: 4px solid #4e73df;
            padding-left: 16px;
        }
    </style>
</head>
<body>

    <div class="app-container">

        <aside class="sidebar">
            <div class="sidebar-top">
                <div class="logo-area">
                    <i class="fa-solid fa-graduation-cap logo-icon"></i>
                    <span class="logo-text">UniVerse SIS</span>
                </div>

                <nav class="nav-menu">
                    <a asp-controller="Home" asp-action="Index" class="nav-item @(currentController == "home" && currentAction == "index" ? "active" : "")">
                        <i class="fa-solid fa-chart-pie"></i>
                        <span>Ana S蓹hif蓹</span>
                    </a>

                    @if (User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-area="AdminPanel" asp-controller="Dashboard" asp-action="Index" class="nav-item @(currentArea == "adminpanel" && currentController == "dashboard" ? "active" : "")">
                                <i class="fa-solid fa-gauge"></i>
                                <span>Admin Panel</span>
                            </a>

                            <a asp-area="AdminPanel" asp-controller="Teacher" asp-action="ShowTeachersTable" class="nav-item @(currentArea == "adminpanel" && currentController == "teacher" ? "active" : "")">
                                <i class="fa-solid fa-chalkboard-user"></i>
                                <span>M眉蓹llim 陌dar蓹si</span>
                            </a>

                            <a asp-controller="Home" asp-action="StudentsPage" class="nav-item @(currentController == "home" && currentAction == "studentspage" ? "active" : "")">
                                <i class="fa-solid fa-user-graduate"></i>
                                <span>T蓹l蓹b蓹 陌dar蓹si</span>
                            </a>
                        }

                        @if (User.IsInRole("Teacher"))
                        {
                            <a asp-controller="Teacher" asp-action="Index" class="nav-item @(currentController == "teacher" && currentAction == "index" ? "active" : "")">
                                <i class="fa-solid fa-chalkboard-user"></i>
                                <span>D蓹rsl蓹rim</span>
                            </a>

                            <a asp-controller="Teacher" asp-action="Index" class="nav-item @(currentController == "teacher" && currentAction == "studentsreportcard" ? "active" : "")">
                                <i class="fa-solid fa-star"></i>
                                <span>Qiym蓹tl蓹ndirm蓹</span>
                            </a>
                        }

                        @if (User.IsInRole("Student"))
                        {
                            <a asp-controller="Student" asp-action="Index" class="nav-item @(currentController == "student" && currentAction == "index" ? "active" : "")">
                                <i class="fa-solid fa-book-reader"></i>
                                <span>Semestr Qiym蓹tl蓹rim</span>
                            </a>

                            @* 馃幆 BDU M蓹ntiqi: F蓹nn se莽imi d眉ym蓹sini yaln谋z t蓹l蓹b蓹y蓹 g枚st蓹ririk v蓹 laz谋mi Action-a ba臒lay谋r谋q *@
                            <a asp-controller="Student" asp-action="AvailableCourses" class="nav-item @(currentController == "student" && currentAction == "availablecourses" ? "active" : "")">
                                <i class="fa-solid fa-book"></i>
                                <span>F蓹nl蓹r & D蓹rsl蓹r</span>
                            </a>
                        }
                    }
                </nav>
            </div>

            <div class="sidebar-profile">
                <div class="profile-info">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="profile-avatar">
                            @(User.Identity.Name?.Substring(0, Math.Min(2, User.Identity.Name.Length)).ToUpper() ?? "US")
                        </div>
                        <div>
                            <h4 class="profile-name">@User.Identity.Name</h4>
                            <span class="profile-email">Giri艧 edilib</span>
                        </div>
                    }
                    else
                    {
                        <div class="profile-avatar">??</div>
                        <div>
                            <h4 class="profile-name">Qonaq</h4>
                            <span class="profile-email">Giri艧 edilm蓹yib</span>
                        </div>
                    }
                </div>

                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-area="" asp-controller="Account" asp-action="Logout" class="logout-btn" title="脟谋x谋艧 et">
                        <i class="fa-solid fa-right-from-bracket"></i>
                    </a>
                }
                else
                {
                    <a asp-area="" asp-controller="Account" asp-action="Login" class="logout-btn" title="Giri艧 et">
                        <i class="fa-solid fa-user"></i>
                    </a>
                }
            </div>
        </aside>

        <main class="main-content">
            <div class="content-body">
                @RenderBody()
            </div>

            <footer class="app-footer">
                <div class="footer-left">
                    <p>&copy; 2026 <strong>UniVerse SIS</strong>. B眉t眉n h眉quqlar qorunur.</p>
                </div>
                <div class="footer-right">
                    <a href="#" class="footer-link">D蓹st蓹k</a>
                    <span class="footer-divider">|</span>
                    <a href="#" class="footer-link">陌stifad蓹莽i Qaydalar谋</a>
                    <span class="footer-divider">|</span>
                    <span class="version-badge">v1.0.0 (MVC)</span>
                </div>
            </footer>
        </main>

    </div>

</body>
</html>