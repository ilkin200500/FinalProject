@using FinalProject.Areas.AdminPanel.ViewModels
@model UpdateStudentVM

<div class="col-md-6 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Tələbə Məlumatlarını Yenilə</h4>

            <form class="forms-sample" asp-action="Update" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @* 🎯 DÜZƏLİŞ: Tələbənin ID-si post zamanı itməsin deyə gizli sahə olaraq əlavə edildi *@
                <input type="hidden" asp-for="Id" />

                <div class="form-group mb-3">
                    <label asp-for="FullName">Ad və Soyad</label>
                    <input asp-for="FullName" class="form-control" placeholder="Ad və Soyad daxil edin" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Email">Email Ünvanı</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="Email daxil edin" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="SpecialityId">İxtisas</label>
                    <select asp-for="SpecialityId" class="form-control" asp-items="@ViewBag.Specialities">
                        <option value="">-- İxtisas Seçin --</option>
                    </select>
                    <span asp-validation-for="SpecialityId" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="PhoneNumber">Telefon Nömrəsi</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="Məs: +99450XXXXXXX" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="BirthDate">Doğum Tarixi</label>
                    @* 🎯 DÜZƏLİŞ: value atributu vasitəsilə tarix yyyy-MM-dd formatına məcburi salındı ki, 0001 problemi tamamilə həll olsun *@
                    <input asp-for="BirthDate" type="date" class="form-control"
                           value="@(Model.BirthDate != DateTime.MinValue ? Model.BirthDate.ToString("yyyy-MM-dd") : "")" />
                    <span asp-validation-for="BirthDate" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Gender">Cins</label>
                    <select asp-for="Gender" class="form-control">
                        <option value="">-- Seçin --</option>
                        <option value="Kişi">Kişi</option>
                        <option value="Qadın">Qadın</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="GroupId">Qrup</label>
                    <select asp-for="GroupId" class="form-control" asp-items="@ViewBag.Groups">
                        <option value="">-- Qrup Seçin --</option>
                    </select>
                    <span asp-validation-for="GroupId" class="text-danger"></span>
                </div>

                @* Redaktə zamanı mövcud dəyərlərin sıfırlanmaması üçün gizli sahələr *@
                <input type="hidden" asp-for="StudentCode" />
                <input type="hidden" asp-for="MemberId" />
                <input type="hidden" asp-for="Average" />

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary me-2">Dəyişiklikləri Yadda Saxla</button>
                    <a class="btn btn-light" asp-controller="Student" asp-action="ShowStudentsTable">Ləğv Et</a>
                </div>
            </form>
        </div>
    </div>
</div>