@using FinalProject.Areas.AdminPanel.ViewModels
@model CreateStudentVM

<div class="col-md-6 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Tələbə Əlavə Et</h4>

            <form class="forms-sample" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="FullName">Ad və Soyad</label>
                    <input asp-for="FullName" class="form-control" placeholder="Ad və Soyad daxil edin" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Email">Email Ünvanı</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="Email daxil edin" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Speciality">İxtisas</label>
                    <input asp-for="Speciality" class="form-control" placeholder="İxtisası daxil edin" />
                    <span asp-validation-for="Speciality" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="PhoneNumber">Telefon Nömrəsi</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="Məs: +99450XXXXXXX" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="BirthDate">Doğum Tarixi</label>
                    <input asp-for="BirthDate" type="date" class="form-control" />
                    <span asp-validation-for="BirthDate" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Gender">Cins</label>
                    <select asp-for="Gender" class="form-control">
                        <option value="">-- Seçin --</option>
                        <option value="Kişi">Kişi</option>
                        <option value="Qadın">Qadın</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="GroupId">Qrup</label>
                    <select asp-for="GroupId" class="form-control"
                            asp-items="@(new SelectList(ViewBag.Groups, "Id", "GroupName"))">
                        <option value="">-- Qrup Seçin --</option>
                    </select>
                    <span asp-validation-for="GroupId" class="text-danger"></span>
                </div>

                <input type="hidden" asp-for="StudentCode" value="ST-2026-001" />
                <input type="hidden" asp-for="MemberId" value="1" />
                <input type="hidden" asp-for="Average" value="0" />

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary me-2">Tələbəni Qeyd Et</button>
                    <a class="btn btn-light" asp-controller="Student" asp-action="ShowStudentsTable">Ləğv Et</a>
                </div>
            </form>
        </div>
    </div>
</div>