@model FinalProject.ViewModels.CreateCourseVM

@{
    ViewData["Title"] = "Yeni Fənn Yarat";
}

<div class="row mt-4">
    <div class="col-md-6 offset-md-3 grid-margin stretch-card">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h4 class="card-title mb-4" style="font-weight: 600; color: #343a40;">Yeni Fənn Yarat</h4>

                <form method="post" asp-action="Create" asp-controller="Course" asp-area="AdminPanel">
                    @Html.AntiForgeryToken()

                    <div class="form-group mb-3">
                        <label asp-for="CourseName" class="form-label fw-bold">Fənnin Adı</label>
                        <input asp-for="CourseName" class="form-control" placeholder="Məs: Riyaziyyat" />
                        <span asp-validation-for="CourseName" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="CourseCode" class="form-label fw-bold">Fənn Kodu</label>
                        <input asp-for="CourseCode" class="form-control" placeholder="Məs: MATH101" />
                        <span asp-validation-for="CourseCode" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Credits" class="form-label fw-bold">Kredit Miqdarı</label>
                        <input asp-for="Credits" type="number" class="form-control" placeholder="Məs: 6" />
                        <span asp-validation-for="Credits" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="SpecialityId" class="form-label fw-bold">Aid Olduğu İxtisas</label>
                        <select asp-for="SpecialityId" class="form-control form-select" asp-items="@(new SelectList(ViewBag.Specialities, "Id", "Name"))">
                            <option value="0">-- İxtisas Seçin --</option>
                        </select>
                        <span asp-validation-for="SpecialityId" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary px-4">Yadda Saxla</button>
                    <a asp-action="Index" class="btn btn-light border ms-2">Ləğv Et</a>
                </form>
            </div>
        </div>
    </div>
</div>