@model IEnumerable<FinalProject.Models.Course>

@{
    ViewData["Title"] = "Fənlərin Siyahısı";
}

<div class="container-fluid pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark font-weight-bold" style="font-size: 26px; margin: 0;">
                <i class="mdi mdi-format-list-bulleted text-primary mr-2"></i> Sistemdəki Bütün Fənlər
            </h2>
            <p class="text-muted small mb-0">Universitet üzrə aktiv tədris olunan fənlərin ümumi bazası</p>
        </div>
        <a asp-action="Create" class="btn btn-success btn-icon-text font-weight-bold text-white shadow-sm" style="border-radius: 8px;">
            <i class="mdi mdi-plus-circle mr-2"></i> Yeni Fənn Əlavə Et
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm font-weight-bold" role="alert" style="border-radius: 8px;">
            <i class="mdi mdi-check-circle mr-2"></i> @TempData["Success"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="card-body p-0 bg-white">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle" style="font-size: 14px;">
                    <thead class="bg-light" style="border-bottom: 2px solid #e3e6f0;">
                        <tr class="text-primary font-weight-bold">
                            <th style="padding: 15px;">Fənn Kodu</th>
                            <th style="padding: 15px;">Fənnin Adı</th>
                            <th style="padding: 15px; text-align: center;">Kredit</th>
                            @* 🎯 DÜZƏLİŞ: Köhnə 'Təyin Olunmuş Müəllim' sütun başlığı buradan silindi *@
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-5">
                                    <i class="mdi mdi-folder-open-outline d-block mb-2" style="font-size: 32px;"></i>
                                    Sistemdə hələ ki heç bir fənn yaradılmayıb.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var course in Model)
                            {
                                <tr style="border-bottom: 1px solid #e3e6f0;">
                                    <td style="padding: 15px;">
                                        <span class="badge bg-light text-primary font-weight-bold px-2 py-1" style="border: 1px solid #4e73df; font-size: 12px;">
                                            @course.CourseCode
                                        </span>
                                    </td>
                                    <td style="padding: 15px;" class="font-weight-bold text-dark">
                                        @course.CourseName
                                    </td>
                                    <td style="padding: 15px; text-align: center;" class="text-muted font-weight-medium">
                                        @course.Credits
                                    </td>
                                    @* 🎯 DÜZƏLİŞ: Müəllim yoxlaması və sütun hüceyrəsi (td) buradan tamamilə təmizləndi *@
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>