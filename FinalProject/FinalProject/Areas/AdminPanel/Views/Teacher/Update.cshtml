@using FinalProject.Areas.AdminPanel.ViewModels
@model UpdateTeacherVM

<div class="col-md-6 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Müəllim Məlumatlarını Yenilə</h4>

            <form class="forms-sample" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="FullName">Müəllimin Adı və Soyadı</label>
                    <input asp-for="FullName" class="form-control" placeholder="Ad və Soyad daxil edin">
                    <span class="text-danger" asp-validation-for="FullName"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Email">Email Ünvanı</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="Email daxil edin">
                    <span class="text-danger" asp-validation-for="Email"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Speciality">İxtisas (Əsas İstiqamət)</label>
                    <input asp-for="Speciality" class="form-control" placeholder="Məs: Proqramlaşdırma, Riyaziyyat">
                    <span class="text-danger" asp-validation-for="Speciality"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Salary">Maaş</label>
                    <input asp-for="Salary" type="number" class="form-control" placeholder="Aylıq maaş miqdarı">
                    <span class="text-danger" asp-validation-for="Salary"></span>
                </div>

                @if (ViewBag.Departments != null)
                {
                    <div class="form-group mb-3">
                        <label asp-for="DepartmentId">Kafedra / Departament</label>
                        <select asp-for="DepartmentId" class="form-control"
                                asp-items="@(new SelectList(ViewBag.Departments, "Id", "DepartmentName"))">
                            <option value="">-- Kafedra Seçin (Məcburi deyil) --</option>
                        </select>
                        <span class="text-danger" asp-validation-for="DepartmentId"></span>
                    </div>
                }

                @* 🎯 DÜZƏLİŞ: Köhnə 'CourseIds' (Redaktə zamanı fənn seçimi) bölməsi buradan tamamilə təmizləndi! *@

                <div class="mt-4">
                    <button type="submit" class="btn btn-success me-2">Yenilə</button>
                    <a class="btn btn-light" asp-controller="Teacher" asp-action="ShowTeachersTable">Ləğv Et</a>
                </div>
            </form>
        </div>
    </div>
</div>