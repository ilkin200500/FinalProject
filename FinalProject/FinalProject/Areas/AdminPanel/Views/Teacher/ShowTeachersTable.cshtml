@using FinalProject.ViewModels
@model TeacherListVM

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

@{
    int Count = 1;
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="card-title mb-0" style="font-weight: 600; color: #343a40;">
                    <i class="fa-solid fa-chalkboard-user me-2 text-primary"></i> Müəllimlərin Siyahısı
                </h4>
                <a asp-controller="Teacher" asp-action="Create" class="btn btn-primary btn-md shadow-sm">
                    <i class="fa-solid fa-user-plus me-1"></i> Müəllim əlavə et
                </a>
            </div>

            <div class="mb-4 p-3 bg-light rounded border">
                <form method="get" asp-action="ShowTeachersTable" asp-controller="Teacher" asp-area="AdminPanel">
                    <div class="row g-2 align-items-center">
                        <div class="col-md-5">
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">
                                    <i class="fa-solid fa-magnifying-glass text-muted"></i>
                                </span>
                                <input type="text" name="search" class="form-control border-start-0"
                                       placeholder="Müəllimin adını yazın..."
                                       value="@Model.SearchText" />
                            </div>
                        </div>
                        <div class="col-md-auto">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fa-solid fa-filter me-1"></i> Axtar
                            </button>
                            @if (!string.IsNullOrEmpty(Model.SearchText))
                            {
                                <a asp-action="ShowTeachersTable" asp-controller="Teacher" asp-area="AdminPanel" class="btn btn-secondary px-3 ms-1">
                                    <i class="fa-solid fa-rotate-left me-1"></i> Təmizlə
                                </a>
                            }
                        </div>
                    </div>
                </form>
            </div>

            @if (!Model.Teachers.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="fa-regular fa-folder-open fa-3x mb-3 text-warning"></i>
                    <h5>Sistemdə heç bir müəllim tapılmadı.</h5>
                    <p class="small text-muted">Yuxarıdakı düymədən və ya fərqli axtarışla yenidən yoxlaya bilərsiniz.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle border">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center" style="width: 5%;">#</th>
                                <th>Müəllim / Kafedra</th>
                                <th>İxtisas</th>
                                <th class="text-center">Maaş</th>
                                <th class="text-center" style="width: 15%;">Əməliyyat</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Teachers)
                            {
                                <tr>
                                    <td class="text-center font-weight-bold text-muted">@Count</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 40px; height: 40px;">
                                                <i class="fa-solid fa-user-tie text-secondary"></i>
                                            </div>
                                            <div>
                                                <span class="d-block font-weight-bold">@item.FullName</span>
                                                <small class="text-muted">
                                                    <i class="fa-solid fa-building-user me-1 text-info"></i>
                                                    @(item.Department != null ? item.Department.DepartmentName : "Kafedra təyin edilməyib")
                                                </small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-dark text-white opacity-75">@item.Speciality</span>
                                    </td>
                                    <td class="text-center font-weight-bold text-success">
                                        @item.Salary AZN
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-controller="Teacher" asp-action="Update" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-warning me-1 rounded" title="Redaktə et">
                                                <i class="fa-solid fa-pen"></i>
                                            </a>
                                            <a asp-controller="Teacher" asp-action="Delete" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-danger rounded" title="Sil"
                                               onclick="return confirm('Bu müəllimi silmək istədiyinizdən əminsiniz?')">
                                                <i class="fa-solid fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                Count++;
                            }
                        </tbody>
                    </table>
                </div>
            }

        </div>
    </div>
</div>