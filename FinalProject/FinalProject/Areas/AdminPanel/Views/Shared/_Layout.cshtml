<!DOCTYPE html>
<html lang="az">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>UniVerse SIS - Admin Panel</title>
    <link rel="stylesheet" href="~/AdminPanel/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="~/AdminPanel/vendors/base/vendor.bundle.base.css">
    <link rel="stylesheet" href="~/AdminPanel/css/style.css">
    <link rel="shortcut icon" href="~/AdminPanel/images/favicon.png" />
</head>

<body>
    <div class="container-scroller">
        <nav class="navbar col-lg-12 col-12 p-0 fixed-top d-flex flex-row">
            <div class="navbar-brand-wrapper d-flex justify-content-center">
                <div class="navbar-brand-inner-wrapper d-flex justify-content-between align-items-center w-100">
                    <a class="navbar-brand brand-logo" asp-area="AdminPanel" asp-controller="Dashboard" asp-action="Index">
                        <span class="text-primary font-weight-bold">UniVerse SIS</span>
                    </a>
                    <a class="navbar-brand brand-logo-mini" asp-area="AdminPanel" asp-controller="Dashboard" asp-action="Index">
                        <span class="text-primary font-weight-bold">U</span>
                    </a>
                    <button class="navbar-toggler navbar-toggler align-self-center" type="button" data-toggle="minimize">
                        <span class="mdi mdi-sort-variant"></span>
                    </button>
                </div>
            </div>
            <div class="navbar-menu-wrapper d-flex align-items-center justify-content-end">
                <ul class="navbar-nav mr-lg-4 w-100">
                    <li class="nav-item nav-search d-none d-lg-block w-100">
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text" id="search">
                                    <i class="mdi mdi-magnify"></i>
                                </span>
                            </div>
                            <input type="text" class="form-control" placeholder="Axtarış..." aria-label="search" aria-describedby="search">
                        </div>
                    </li>
                </ul>
                <ul class="navbar-nav navbar-nav-right">
                    <li class="nav-item nav-profile dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" id="profileDropdown">
                            <span class="nav-profile-name">@User.Identity.Name</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-right navbar-dropdown" aria-labelledby="profileDropdown">
                            <a class="dropdown-item">
                                <i class="mdi mdi-settings text-primary"></i>
                                Parametrlər
                            </a>
                            <a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Logout">
                                <i class="mdi mdi-logout text-primary"></i>
                                Çıxış
                            </a>
                        </div>
                    </li>
                </ul>
                <button class="navbar-toggler navbar-toggler-right d-lg-none align-self-center" type="button" data-toggle="offcanvas">
                    <span class="mdi mdi-menu"></span>
                </button>
            </div>
        </nav>

        <div class="container-fluid page-body-wrapper">
            <nav class="sidebar sidebar-offcanvas" id="sidebar">
                <ul class="nav">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="AdminPanel" asp-controller="Dashboard" asp-action="Index">
                            <i class="mdi mdi-view-dashboard menu-icon"></i>
                            <span class="menu-title">Dashboard</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-area="AdminPanel" asp-controller="Student" asp-action="ShowStudentsTable">
                            <i class="mdi mdi-account-multiple menu-icon"></i>
                            <span class="menu-title">Tələbələr</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-area="AdminPanel" asp-controller="Teacher" asp-action="ShowTeachersTable">
                            <i class="mdi mdi-account-card-details menu-icon"></i>
                            <span class="menu-title">Müəllimlər</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-area="AdminPanel" asp-controller="Group" asp-action="Index">
                            <i class="mdi mdi-layers menu-icon"></i>
                            <span class="menu-title">Qruplar</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-area="AdminPanel" asp-controller="Course" asp-action="Index">
                            <i class="mdi mdi-book-open-page-variant menu-icon"></i>
                            <span class="menu-title">Fənlər</span>
                        </a>
                    </li>

                    @* 🛠️ İXTİSASLAR MENYUSU (ƏLAVƏ OLUNDU) *@
                    <li class="nav-item">
                        <a class="nav-link" asp-area="AdminPanel" asp-controller="Speciality" asp-action="Index">
                            <i class="mdi mdi-certificate menu-icon"></i>
                            <span class="menu-title">İxtisaslar</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-area="AdminPanel" asp-controller="Schedule" asp-action="Index">
                            <i class="mdi mdi-calendar-clock menu-icon"></i>
                            <span class="menu-title">Dərs Cədvəli</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="main-panel">
                <div class="content-wrapper">
                    @RenderBody()
                </div>

                <footer class="footer">
                    <div class="d-sm-flex justify-content-center justify-content-sm-between">
                        <span class="text-muted text-center text-sm-left d-block d-sm-inline-block">Copyright © 2026 <strong>UniVerse SIS</strong></span>
                        <span class="float-none float-sm-right d-block mt-1 mt-sm-0 text-center">Admin Panel v1.0</span>
                    </div>
                </footer>
            </div>
        </div>
    </div>
    <script src="~/AdminPanel/vendors/base/vendor.bundle.base.js"></script>
    <script src="~/AdminPanel/js/off-canvas.js"></script>
    <script src="~/AdminPanel/js/hoverable-collapse.js"></script>
    <script src="~/AdminPanel/js/template.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>