@model IEnumerable<FinalProject.Models.Schedule>

@{
    ViewData["Title"] = "Dərs Cədvəli Siyahısı";

    // Model-dən bütün təkrar olunmayan (Distinct) qrupları çıxarırıq
    var groups = Model != null
        ? Model.Where(s => s.Group != null)
               .Select(s => s.Group)
               .GroupBy(g => g.Id)
               .Select(g => g.First())
               .ToList()
        : new List<FinalProject.Models.Group>();
}

<div class="container-fluid mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-1"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Qruplar üzrə Dərs Cədvəli</h1>
            <p class="text-muted small mb-0">Hər qrup üçün cədvəli ayrı-ayrı tablardan izləyə bilərsiniz.</p>
        </div>
        <a asp-action="Create" class="btn btn-sm btn-primary shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50"></i> Yeni Cədvəl Əlavə Et
        </a>
    </div>

    @if (groups == null || !groups.Any())
    {
        <div class="card shadow mb-4">
            <div class="card-body text-center py-5 text-muted">
                <i class="fas fa-calendar-times display-4 mb-3 text-secondary"></i>
                <p class="mb-0">Hələ ki cədvələ heç bir dərs əlavə edilməyib.</p>
            </div>
        </div>
    }
    else
    {
        <!-- 1. QRUP SEÇİM TABLARI (SEKMƏLƏRİ) -->
        <ul class="nav nav-tabs mb-3" id="scheduleTab" role="tablist">
            @for (int i = 0; i < groups.Count; i++)
            {
                var group = groups[i];
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(i == 0 ? "active fw-bold" : "")"
                            id="group-tab-@group.Id"
                            data-bs-toggle="tab"
                            data-bs-target="#group-pane-@group.Id"
                            type="button"
                            role="tab"
                            aria-controls="group-pane-@group.Id"
                            aria-selected="@(i == 0 ? "true" : "false")">
                        <i class="fas fa-users me-1"></i> @group.GroupName
                    </button>
                </li>
            }
        </ul>

        <!-- 2. HƏR QRUPA AİD CƏDVƏL (TAB KONTENTİ) -->
        <div class="tab-content" id="scheduleTabContent">
            @for (int i = 0; i < groups.Count; i++)
            {
                var group = groups[i];
                var groupSchedules = Model.Where(s => s.GroupId == group.Id).OrderBy(s => s.DayOfWeek).ThenBy(s => s.StartTime).ToList();

                <div class="tab-pane fade @(i == 0 ? "show active" : "")"
                     id="group-pane-@group.Id"
                     role="tabpanel"
                     aria-labelledby="group-tab-@group.Id">

                    <div class="card shadow mb-4">
                        <div class="card-header py-3 bg-light d-flex justify-content-between align-items-center">
                            <h6 class="m-0 font-weight-bold text-primary">
                                <i class="fas fa-graduation-cap me-1"></i> @group.GroupName Qrupunun Həftəlik Cədvəli
                            </h6>
                            <span class="badge bg-secondary">Cəmi: @groupSchedules.Count dərs</span>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-bordered table-hover align-middle" width="100%" cellspacing="0">
                                    <thead class="table-dark">
                                        <tr>
                                            <th>Gün</th>
                                            <th>Saat</th>
                                            <th>Fənn (Kod)</th>
                                            <th>Müəllim</th>
                                            <th>Auditoriya</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (groupSchedules.Any())
                                        {
                                            foreach (var item in groupSchedules)
                                            {
                                                <tr>
                                                    <td>
                                                        <span class="badge bg-primary text-white">@item.DayOfWeek.ToString()</span>
                                                    </td>
                                                    <td class="fw-bold">
                                                        @item.StartTime.ToString(@"hh\:mm") - @item.EndTime.ToString(@"hh\:mm")
                                                    </td>
                                                    <td>
                                                        @(item.Course != null ? $"{item.Course.CourseName} ({item.Course.CourseCode})" : "—")
                                                    </td>
                                                    <td>
                                                        @(item.Teacher != null ? item.Teacher.FullName : "Müəllim təyin olunmayıb")
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-info text-dark">@(string.IsNullOrEmpty(item.Classroom) ? "Təyin edilməyib" : item.Classroom)</span>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="5" class="text-center text-muted">Bu qrup üçün hələ ki dərs cədvəli yoxdur.</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>
            }
        </div>
    }
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}