@using FinalProject.Models
@model List<Student>
@{
    int Count = 1;
}
<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Telebelerin Siyahisi</h4>
            <a asp-controller="Member" asp-action="Create"></a>
           
            <div class="table-responsive pt-3">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>
                                Nomre
                            </th>
                            <th>
                                Telebe
                            </th>
                            <th>
                                Email
                            </th>
                            <th>
                                Ixtisas
                            </th>
                            <th>
                                Ortalama
                            </th>
                            <th>
                                Emeliyyat


                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var item in Model)
                        {
                            <tr>
                                <td>
                                    @Count
                                </td>
                                <td>
                                    @item.FullName
                                </td>
                                
                                <td>
                                    @item.Email
                                </td>
                                <td>
                                    @item.Speciality
                                </td>
                                <td>@item.Average</td>
                                <td>
                                    <a>Duzeld</a>
                                    <a>Sil</a>
                                </td>
                            </tr>
                            Count++;
                        }
                       
                 
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

