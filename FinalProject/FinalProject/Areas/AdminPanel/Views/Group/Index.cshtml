@model IEnumerable<FinalProject.Models.Group>

@{
    ViewData["Title"] = "Qrupların Siyahısı";
}

<div class="container-fluid mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="mdi mdi-check-circle mr-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="mdi mdi-alert-circle mr-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Mövcud Qruplar</h1>
        <a asp-action="Create" class="btn btn-sm btn-primary shadow-sm">
            <i class="mdi mdi-plus fs-6"></i> Yeni Qrup Yarat
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped align-middle" width="100%" cellspacing="0">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 100px;">ID</th>
                            <th>Qrup Adı</th>
                            <th class="text-center" style="width: 150px;">Əməliyyatlar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td><strong>@item.GroupName</strong></td>
                                    <td class="text-center">
                                        <form asp-area="AdminPanel" asp-controller="Group" asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu qrupu silmək istədiyinizdən əminsiniz?');" style="display:inline-block;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger shadow-sm">
                                                <i class="mdi mdi-trash-can mr-1"></i> Sil
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">Sistemdə hələ heç bir qrup yaradılmayıb.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>